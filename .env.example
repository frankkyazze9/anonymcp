# AnonyMCP Configuration
# Copy this file to .env and modify as needed

# Server
ANONYMCP_HOST=0.0.0.0
ANONYMCP_PORT=8100
ANONYMCP_TRANSPORT=stdio              # stdio | streamable-http
ANONYMCP_LOG_LEVEL=INFO

# TLS (HTTP transport only)
# ANONYMCP_TLS_CERTFILE=/path/to/cert.pem
# ANONYMCP_TLS_KEYFILE=/path/to/key.pem
# ANONYMCP_TLS_KEYFILE_PASSWORD=
# ANONYMCP_TLS_CA_CERTS=              # set for mutual TLS (client cert verification)

# Authentication (HTTP transport only)
ANONYMCP_REQUIRE_AUTH=false
# ANONYMCP_API_KEYS=pipeline-key:read,admin-key:admin  # key:role pairs

# Safety limits
ANONYMCP_MAX_TEXT_LENGTH=100000        # max input chars (0 = unlimited)

# Policy
ANONYMCP_POLICY_PATH=./policies/default.yaml
ANONYMCP_SCORE_THRESHOLD=0.4
ANONYMCP_DEFAULT_LANGUAGE=en

# Audit
ANONYMCP_AUDIT_ENABLED=true
ANONYMCP_AUDIT_LOG_PATH=./audit/anonymcp.jsonl
ANONYMCP_AUDIT_LOG_ORIGINAL=false

# Alerting (optional)
ALERT_WEBHOOK_URL=

# Presidio NLP Backend
ANONYMCP_NLP_ENGINE=spacy             # spacy | transformers
ANONYMCP_SPACY_MODEL=en_core_web_lg
