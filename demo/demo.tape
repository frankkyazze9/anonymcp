# AnonyMCP Demo Recording — generates a GIF for the README
# Run with: vhs demo/demo.tape

Output demo/anonymcp-demo.gif

Set Shell "zsh"
Set FontSize 14
Set Width 1200
Set Height 800
Set Padding 20
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms

Type "cd ~/Desktop/anonymcp"
Enter
Sleep 500ms

Type "# AnonyMCP — Data Governance MCP Server"
Enter
Sleep 1s

Type "uv run python demo/demo_cli.py"
Enter
Sleep 30s
